# --- Neon Postgres（取引ツール専用の Project を新規作成して使う） ---
# 実行時クエリ用（pooled / -pooler エンドポイント。?sslmode=require を付与）
DATABASE_URL="postgresql://USER:PASSWORD@ep-xxxx-pooler.REGION.aws.neon.tech/neondb?sslmode=require"
# Prisma migrate 用（直結エンドポイント）
DIRECT_URL="postgresql://USER:PASSWORD@ep-xxxx.REGION.aws.neon.tech/neondb?sslmode=require"

# --- OpenAI ---
OPENAI_API_KEY=
# 任意（用途別モデル上書き）
OPENAI_MODEL_TRADE_REVIEW=
OPENAI_MODEL_CONDITION_DISCOVERY=

# --- market-alert からのスナップショット投入の共有シークレット ---
# market-alert 側の TRADE_JOURNAL_INGEST_SECRET と同じ値にする
INGEST_SECRET=

# --- 分析で Yahoo から日経データを取得するシンボル（任意・既定 NIY=F→^N225） ---
NIKKEI_SYMBOL=NIY=F

# --- 容量削減: 生OHLC窓を保持する日数（既定14日。超過分は prune で null 化） ---
RAW_OHLC_RETENTION_DAYS=14

# --- Vercel Cron（毎日の自動 prune）認証用。Vercel が自動付与する想定 ---
CRON_SECRET=
