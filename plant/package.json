{
  "name": "plant-identify",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -p 3001",
    "build": "node scripts/prisma-with-env.cjs generate && next build",
    "start": "next start -p 3001",
    "lint": "next lint",
    "postinstall": "node scripts/prisma-with-env.cjs generate",
    "prisma:generate": "node scripts/prisma-with-env.cjs generate",
    "prisma:migrate": "node scripts/prisma-with-env.cjs migrate dev",
    "prisma:deploy": "node scripts/prisma-with-env.cjs migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^5.16.0",
    "next": "14.2.5",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.30",
    "@types/react": "^18.2.66",
    "@types/react-dom": "^18.2.22",
    "autoprefixer": "^10.4.18",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.35",
    "dotenv": "^16.4.5",
    "prisma": "^5.16.0",
    "tailwindcss": "^3.4.3",
    "typescript": "^5.4.0"
  }
}
