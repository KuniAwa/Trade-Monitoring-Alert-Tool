# PostgreSQL (Neon / Vercel Postgres など) — localhost の Docker でも可
DATABASE_URL="postgresql://user:pass@host:5432/plant?sslmode=require"

# 合言葉（家族内で共有。長めに）
APP_PASSCODE="change-me-please"
# ランダムな十分長い文字列（HMAC 用）
AUTH_SECRET="generate-a-long-random-string"

# https://my.plantnet.org で発行
PLANTNET_API_KEY=""

# 既定: k-world-flora。地域プロジェクト名に変更可
# PLANTNET_PROJECT="k-world-flora"

# https://platform.openai.com
OPENAI_API_KEY=""

# Prisma CLI 用: 既定では .env のみ参照する。本プロジェクトは `npm run prisma:deploy` で
# .env と .env.local の両方を読み込んでから migrate する（DATABASE_URL はどちらかに記載可）。
#
# Vercel: Root Directory を plant に。環境変数に上記を登録。初回 DB に `npm run prisma:deploy`
